# Galaxy Media server configuration
# Copy to /etc/galaxy-media/config.env (production) or server/.env (development)
# and fill in real values. NEVER commit the real file.

# PostgreSQL connection
DATABASE_URL=postgres://galaxy:CHANGE_ME@localhost:5432/galaxy_media

# HTTP listener (nginx proxies to this; keep it on localhost in production)
HOST=127.0.0.1
PORT=8080

# Public origin clients use to reach the server (used in signed URLs, pairing screen)
BASE_URL=https://signage.example.com

# Secret for signing JWTs. Generate with: openssl rand -hex 48
JWT_SECRET=CHANGE_ME

# 32-byte hex key for AES-256-GCM encryption of sensitive DB columns (TOTP secrets, SMTP creds).
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME

# Directory for uploaded media (must be writable by the service user)
MEDIA_DIR=/var/lib/galaxy-media/media

# Max upload size in megabytes
MAX_UPLOAD_MB=512

# Initial MSP admin - used only by the first migration/seed when no users exist
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_LONG_RANDOM

# Offline screen alerts (optional - leave unset to disable).
# A screen silent for OFFLINE_ALERT_MINUTES emails ALERT_EMAILS; recovery emails too.
#SMTP_HOST=smtp.example.com
#SMTP_PORT=587
#SMTP_USER=alerts@example.com
#SMTP_PASS=CHANGE_ME
#SMTP_FROM="Galaxy Media <alerts@example.com>"
#ALERT_EMAILS=you@example.com,noc@example.com
#OFFLINE_ALERT_MINUTES=5

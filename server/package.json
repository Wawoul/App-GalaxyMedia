{
  "name": "galaxy-media-server",
  "version": "1.0.0",
  "description": "Galaxy Media - self-hosted digital signage server",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node -e \"fs.cpSync('src/db/migrations','dist/db/migrations',{recursive:true})\"",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.2.0",
    "@fastify/websocket": "^11.2.0",
    "argon2": "^0.44.0",
    "dotenv": "^17.2.1",
    "fastify": "^5.4.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^9.0.3",
    "otplib": "^12.0.1",
    "pg": "^8.16.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.15.4",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}

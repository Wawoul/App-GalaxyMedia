# Docker Compose configuration. Copy to .env and fill in - never commit .env.

# Public URL clients use to reach the server (behind your TLS proxy/tunnel)
BASE_URL=https://signage.example.com

# Database password. Generate: openssl rand -hex 24
DB_PASSWORD=CHANGE_ME

# JWT signing secret. Generate: openssl rand -hex 48
JWT_SECRET=CHANGE_ME

# 32-byte hex key for encrypting secrets at rest. Generate: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME

# First admin account, created on first start only
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_LONG_RANDOM

# Max media upload size (MB)
MAX_UPLOAD_MB=512

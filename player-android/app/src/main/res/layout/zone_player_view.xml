<?xml version="1.0" encoding="utf-8"?>
<!-- surface_type=texture_view (constructor-only, hence XML): SurfaceView video
     is composited as a hardware overlay on TV SoCs, which PixelCopy cannot
     read - support screenshots came out black wherever video was playing.
     TextureView renders inside normal GPU composition, so captures work. -->
<androidx.media3.ui.PlayerView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:surface_type="texture_view"
    app:use_controller="false" />
